---
import { faqs } from '../../data/comfort-plan';
---

<section class="py-section-gap bg-surface px-margin-mobile md:px-margin-desktop">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-4">
        {faqs.heading}
      </h2>
    </div>

    <div class="faq-accordion flex flex-col gap-4">
      {
        faqs.items.map((item, i) => (
          <details
            class="group bg-surface-light rounded-card border border-outline-variant/30 overflow-hidden"
            open={i === 0}
          >
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none p-6 font-headline-md text-lg text-on-surface">
              {item.q}
              <span class="expand-icon material-symbols-outlined text-primary shrink-0">
                expand_more
              </span>
            </summary>
            <div class="px-6 pb-6 -mt-1 font-body-md text-body-md text-on-surface-variant">
              {item.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
