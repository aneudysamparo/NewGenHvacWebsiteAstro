---
import { differentiators } from '../../data/home';

// Literal class strings so Tailwind can detect them at build time.
const iconWrap: Record<string, string> = {
  primary: 'bg-primary/10 text-primary',
  'emergency-orange': 'bg-emergency-orange/10 text-emergency-orange',
  secondary: 'bg-secondary/10 text-secondary',
};
---

<section
  class="py-16 bg-surface-light border-b border-outline-variant/20 px-margin-mobile md:px-margin-desktop"
>
  <div class="max-w-container-max mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        differentiators.map((item) => (
          <div class="flex items-center gap-4">
            <div class={`${iconWrap[item.color]} p-4 rounded-full shrink-0`}>
              <span class="material-symbols-outlined text-3xl">{item.icon}</span>
            </div>
            <div>
              <h3 class="font-headline-md text-lg text-on-surface mb-1">{item.title}</h3>
              <p class="font-body-md text-sm text-on-surface-variant">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
