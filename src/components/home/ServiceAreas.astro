---
import { serviceAreas } from '../../data/home';
import { business } from '../../data/business';
import MapEmbed from '../layout/MapEmbed.astro';
---

<section
  class="py-section-gap bg-surface-light px-margin-mobile md:px-margin-desktop border-b border-outline-variant/20"
>
  <div class="max-w-container-max mx-auto flex flex-col md:flex-row items-center gap-12">
    <div class="flex-1">
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-4">
        {serviceAreas.heading}
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-6">{serviceAreas.desc}</p>
      <ul class="grid grid-cols-2 gap-4">
        {
          serviceAreas.towns.map((town) => (
            <li class="flex items-center gap-2 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary">check_circle</span>
              {town}
            </li>
          ))
        }
      </ul>
      <a
        href="/service-areas"
        class="inline-flex items-center gap-1 mt-6 text-primary font-label-md hover:gap-2 transition-all"
      >
        View all service areas
        <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </a>
    </div>

    <div class="flex-1 w-full h-64 md:h-80 rounded-card overflow-hidden border border-outline-variant/30 shadow-sm">
      <MapEmbed
        query={`${business.address.city}, ${business.address.state}`}
        zoom={9}
        title="NewGen HVAC service area — Merrimack Valley & Southern New Hampshire"
      />
    </div>
  </div>
</section>
