---
import { leadForm } from '../../data/home';

const inputClass =
  'w-full rounded-btn border-outline-variant/50 focus:border-primary focus:ring-primary bg-surface-light px-4 py-3 font-body-md text-on-surface';
---

<div
  id="request-estimate"
  class="bg-white rounded-card p-8 card-shadow card-top-border border border-outline-variant/20 relative z-20 scroll-mt-24"
>
  <div class="text-center mb-6">
    <h2 class="font-headline-md text-headline-md text-on-surface mb-2">{leadForm.heading}</h2>
    <p class="font-body-md text-body-md text-on-surface-variant">{leadForm.subheading}</p>
  </div>

  {/* TODO(lead-endpoint): submission is intentionally NOT wired. Per CLAUDE.md
      §3/§9 confirm the destination (likely GoHighLevel) before connecting.
      onsubmit returns false so the form cannot post anywhere yet. */}
  <form class="flex flex-col gap-4" method="post" action="#" novalidate onsubmit="return false;">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="sr-only" for="first-name">First Name</label>
        <input
          class={inputClass}
          id="first-name"
          name="first_name"
          placeholder="First Name"
          type="text"
          autocomplete="given-name"
          required
        />
      </div>
      <div>
        <label class="sr-only" for="last-name">Last Name</label>
        <input
          class={inputClass}
          id="last-name"
          name="last_name"
          placeholder="Last Name"
          type="text"
          autocomplete="family-name"
          required
        />
      </div>
    </div>

    <div>
      <label class="sr-only" for="phone">Phone Number</label>
      <input
        class={inputClass}
        id="phone"
        name="phone"
        placeholder="Phone Number"
        type="tel"
        autocomplete="tel"
        required
      />
    </div>

    <div>
      <label class="sr-only" for="email">Email Address</label>
      <input
        class={inputClass}
        id="email"
        name="email"
        placeholder="Email Address"
        type="email"
        autocomplete="email"
        required
      />
    </div>

    <div>
      <label class="sr-only" for="service">Service Needed</label>
      <select class={`${inputClass} text-on-surface-variant`} id="service" name="service" required>
        <option disabled selected value="">Select Service Needed...</option>
        {leadForm.serviceOptions.map((opt) => <option value={opt.value}>{opt.label}</option>)}
      </select>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="sr-only" for="zip">Town/ZIP</label>
        <input
          class={inputClass}
          id="zip"
          name="zip"
          placeholder="Town or ZIP"
          type="text"
          autocomplete="postal-code"
          required
        />
      </div>
      <div>
        <label class="sr-only" for="language">Preferred Language</label>
        <select class={`${inputClass} text-on-surface-variant`} id="language" name="language">
          {leadForm.languageOptions.map((opt) => <option value={opt.value}>{opt.label}</option>)}
        </select>
      </div>
    </div>

    <button
      class="w-full bg-primary-container hover:bg-primary text-white font-label-md text-[16px] py-4 rounded-btn mt-2 transition-colors flex justify-center items-center gap-2"
      type="submit"
    >
      {leadForm.submitLabel}
      <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
    </button>

    <div class="text-center mt-3">
      <p
        class="font-label-md text-[13px] text-primary flex items-center justify-center gap-1 mb-2"
      >
        <span class="material-symbols-outlined text-[16px]">check_circle</span>
        {leadForm.reassurance}
      </p>
      <p class="text-[11px] text-outline leading-tight mt-3">{leadForm.smsConsent}</p>
    </div>
  </form>
</div>
