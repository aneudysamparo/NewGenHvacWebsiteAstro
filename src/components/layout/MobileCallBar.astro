---
import { business } from '../../data/business';
---

<div
  class="fixed bottom-0 w-full z-50 md:hidden bg-primary shadow-[0_-4px_12px_rgba(0,0,0,0.15)] transition-transform duration-300"
>
  <div class="flex w-full justify-center items-center">
    <a
      class="flex items-center justify-center gap-2 py-4 w-full text-on-primary font-label-md text-label-md font-bold uppercase tracking-wider active:bg-primary-container active:scale-95 transition-all"
      href={business.phone.href}
    >
      <span class="material-symbols-outlined fill text-xl">call</span>
      Call Now
    </a>
  </div>
</div>
