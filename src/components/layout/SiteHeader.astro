---
import { nav } from '../../data/site';
---

<nav
  class="bg-surface/90 backdrop-blur-md sticky top-0 w-full z-50 shadow-sm border-b border-outline-variant/30 transition-all duration-300"
>
  <div
    class="flex justify-between items-center h-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto"
  >
    <!-- Brand -->
    <a class="flex items-center" href="/">
      <img
        src="/images/horizontal_logo.png"
        alt="New Generation HVAC"
        width="1640"
        height="521"
        class="h-10 sm:h-12 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {
        nav.links.map((link) => (
          <a
            class="text-on-surface-variant hover:text-primary font-body-md transition-colors duration-200"
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden text-on-surface p-2 -mr-2"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="material-symbols-outlined text-[28px]" data-menu-icon>menu</span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-outline-variant/30 bg-surface">
    <ul class="flex flex-col px-margin-mobile py-2 max-w-container-max mx-auto">
      {
        nav.links.map((link) => (
          <li>
            <a
              class="block py-3 text-on-surface hover:text-primary font-body-md border-b border-outline-variant/15 last:border-b-0 transition-colors"
              href={link.href}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = toggle?.querySelector('[data-menu-icon]');

  if (toggle && menu && icon) {
    const setOpen = (open) => {
      menu.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      icon.textContent = open ? 'close' : 'menu';
    };

    toggle.addEventListener('click', () => setOpen(menu.classList.contains('hidden')));
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  }
</script>
