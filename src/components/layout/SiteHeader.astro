---
import { business } from '../../data/business';
import { nav } from '../../data/site';
---

<nav
  class="bg-surface/90 backdrop-blur-md sticky top-0 w-full z-50 shadow-sm border-b border-outline-variant/30 transition-all duration-300"
>
  <div
    class="flex justify-between items-center h-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto"
  >
    <!-- Brand -->
    <a class="flex items-center" href="/">
      <img
        src="/images/horizontal_logo.png"
        alt="New Generation HVAC"
        width="1640"
        height="521"
        class="h-10 sm:h-12 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {
        nav.links.map((link) => (
          <a
            class="text-on-surface-variant hover:text-primary font-body-md transition-colors duration-200"
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Actions -->
    <div class="hidden md:flex items-center gap-6">
      <a
        class="font-label-md text-label-md text-on-surface hover:text-primary flex items-center gap-2"
        href={business.phone.href}
      >
        <span class="material-symbols-outlined">call</span>
        {business.phone.display}
      </a>
      <a
        class="bg-primary hover:bg-primary/90 text-on-primary font-label-md text-label-md px-6 py-3 rounded-btn transition-colors"
        href="#request-estimate"
      >
        Free Estimate
      </a>
      <button
        class="text-on-surface hover:text-primary flex items-center justify-center p-2 rounded-full hover:bg-surface-container-low transition-colors"
        type="button"
        aria-label="Switch language"
      >
        <span class="material-symbols-outlined">language</span>
      </button>
    </div>

    <!-- Mobile menu toggle -->
    <button class="md:hidden text-on-surface p-2" type="button" aria-label="Open menu">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
</nav>
