---
import { business } from '../../data/business';
import MembershipCallout from '../services/MembershipCallout.astro';
import type { ServiceDetail } from '../../data/service-details';

interface Props {
  service: ServiceDetail;
}
const { service } = Astro.props;

// Per-service photo: public/images/services/new-gen-hvac-<slug>.png (service.image).

// Literal class strings so Tailwind detects them.
const featureAccent: Record<string, string> = {
  primary: 'bg-primary/10 text-primary',
  secondary: 'bg-secondary/10 text-secondary',
  'emergency-orange': 'bg-emergency-orange/10 text-emergency-orange',
};
---

<!-- Breadcrumbs -->
<nav
  aria-label="Breadcrumb"
  class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-6"
>
  <ol class="flex items-center gap-2 text-on-surface-variant font-label-md text-label-md flex-wrap">
    <li><a class="hover:text-primary flex items-center gap-1" href="/"><span class="material-symbols-outlined text-[18px]">home</span>Home</a></li>
    <li aria-hidden="true"><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
    <li><a class="hover:text-primary" href="/services">Services</a></li>
    <li aria-hidden="true"><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
    <li class="text-primary font-bold" aria-current="page">{service.breadcrumb}</li>
  </ol>
</nav>

<!-- Hero -->
<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap">
  <div class="relative overflow-hidden rounded-card bg-primary-container p-8 md:p-14 lg:p-20 flex flex-col lg:flex-row items-center gap-12">
    <div class="relative z-10 lg:w-3/5 text-center lg:text-left">
      <span class="inline-block bg-white/10 text-white border border-white/20 px-4 py-1.5 rounded-full font-label-md text-label-md mb-6">
        {service.hero.badge}
      </span>
      <h1 class="font-headline-xl text-headline-lg-mobile md:text-headline-xl text-white mb-6 leading-tight">
        {service.hero.title}
      </h1>
      <p class="font-body-lg text-body-lg text-white/85 max-w-2xl mb-10 mx-auto lg:mx-0">
        {service.hero.subcopy}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <button
          type="button"
          data-lead-modal-open
          data-lead-title={`Free Estimate — ${service.breadcrumb}`}
          data-lead-service={service.leadService}
          class="bg-white text-primary px-8 py-4 rounded-btn font-label-md font-bold shadow-lg hover:bg-surface-container-low transition-all"
        >
          Free Estimate
        </button>
        <a
          class="flex items-center justify-center gap-2 border-2 border-white/30 text-white px-8 py-4 rounded-btn font-label-md font-bold hover:bg-white/10 transition-all"
          href={business.phone.href}
        >
          <span class="material-symbols-outlined">call</span>
          Call {business.phone.display}
        </a>
      </div>
    </div>

    <div class="relative lg:w-2/5 w-full">
      <img
        src={service.image}
        alt={`NewGen HVAC — ${service.breadcrumb}`}
        width="640"
        height="640"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover rounded-2xl shadow-2xl border-4 border-white/10 aspect-square"
      />
      <div class="absolute -bottom-5 -right-5 bg-secondary text-white p-5 rounded-2xl shadow-xl hidden md:block">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined fill text-4xl">{service.hero.stat.icon}</span>
          <div>
            <p class="text-label-md opacity-80 uppercase tracking-widest">{service.hero.stat.label}</p>
            <p class="font-headline-md text-lg font-bold leading-none">{service.hero.stat.value}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Key Features & Benefits -->
<section class="bg-surface-container-low py-section-gap px-margin-mobile md:px-margin-desktop">
  <div class="max-w-container-max mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary mb-4">
        {service.features.heading}
      </h2>
      <p class="font-body-md text-body-md text-on-surface-variant">{service.features.subcopy}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        service.features.items.map((item) => (
          <div class="bg-white p-8 rounded-card border border-outline-variant/30 card-shadow flex flex-col gap-4">
            <div class={`w-12 h-12 ${featureAccent[item.accent]} rounded-xl flex items-center justify-center`}>
              <span class="material-symbols-outlined fill">{item.icon}</span>
            </div>
            <h3 class="font-headline-md text-headline-md text-on-surface">{item.title}</h3>
            <p class="font-body-md text-on-surface-variant">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Specialty / secondary section -->
<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-section-gap">
  <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
    <div class="lg:w-1/2 order-2 lg:order-1">
      <div class="relative">
        <img
          src={service.image}
          alt={`NewGen HVAC — ${service.breadcrumb} service`}
          width="640"
          height="480"
          loading="lazy"
          decoding="async"
          class="w-full aspect-[4/3] object-cover rounded-card shadow-lg border border-outline-variant/20"
        />
        <div class="absolute -top-4 -left-4 bg-white shadow-xl px-6 py-4 rounded-xl border border-outline-variant/30">
          <p class="font-headline-md text-primary font-bold">{service.specialty.stat.value}</p>
          <p class="font-label-md text-on-surface-variant">{service.specialty.stat.label}</p>
        </div>
      </div>
    </div>
    <div class="lg:w-1/2 order-1 lg:order-2">
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary mb-6">
        {service.specialty.heading}
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-8 leading-relaxed">
        {service.specialty.body}
      </p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          service.specialty.checklist.map((point) => (
            <li class="flex items-center gap-2 text-on-surface font-semibold">
              <span class="material-symbols-outlined text-secondary">check_circle</span>
              {point}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

{service.showMembership && <MembershipCallout />}

<!-- FAQ -->
<section class="bg-surface-light py-section-gap px-margin-mobile md:px-margin-desktop">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-4">
        Frequently Asked Questions
      </h2>
    </div>
    <div class="faq-accordion flex flex-col gap-4">
      {
        service.faqs.map((item, i) => (
          <details class="group bg-white rounded-card border border-outline-variant/30 overflow-hidden" open={i === 0}>
            <summary class="flex justify-between items-center gap-4 p-6 cursor-pointer list-none hover:bg-surface-light transition-colors">
              <h3 class="font-headline-md text-lg text-on-surface">{item.q}</h3>
              <span class="expand-icon material-symbols-outlined text-primary shrink-0">expand_more</span>
            </summary>
            <div class="px-6 pb-6 border-t border-outline-variant/10 pt-4 font-body-md text-on-surface-variant leading-relaxed">
              {item.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
