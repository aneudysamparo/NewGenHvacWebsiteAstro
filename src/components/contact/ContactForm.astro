---
import { contact } from '../../data/contact';
const f = contact.form;

const inputClass =
  'w-full rounded-btn border-outline-variant/50 focus:border-primary focus:ring-primary bg-surface-light px-4 py-3 font-body-md text-on-surface';
---

<div
  id="request-estimate"
  class="bg-white rounded-card card-top-border card-shadow border border-outline-variant/20 p-6 sm:p-8 scroll-mt-24"
>
  <div class="mb-6">
    <h2 class="font-headline-md text-headline-md text-on-surface mb-2">{f.heading}</h2>
    <p class="font-body-md text-body-md text-on-surface-variant">{f.subheading}</p>
  </div>

  {/* TODO(lead-endpoint): NOT wired — confirm Jobber/GoHighLevel destination
      before connecting (CLAUDE.md §3/§9). onsubmit returns false for now. */}
  <form class="flex flex-col gap-4" method="post" action="#" novalidate onsubmit="return false;">
    <div>
      <label class="sr-only" for="c-name">Full Name</label>
      <input class={inputClass} id="c-name" name="name" placeholder="Full Name" type="text" autocomplete="name" required />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="sr-only" for="c-phone">Phone Number</label>
        <input class={inputClass} id="c-phone" name="phone" placeholder="Phone Number" type="tel" autocomplete="tel" required />
      </div>
      <div>
        <label class="sr-only" for="c-email">Email Address</label>
        <input class={inputClass} id="c-email" name="email" placeholder="Email Address" type="email" autocomplete="email" required />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="sr-only" for="c-service">Service Needed</label>
        <select class={`${inputClass} text-on-surface-variant`} id="c-service" name="service" required>
          <option disabled selected value="">Service Needed...</option>
          {f.serviceOptions.map((opt) => <option value={opt}>{opt}</option>)}
        </select>
      </div>
      <div>
        <label class="sr-only" for="c-zip">Address or Town</label>
        <input class={inputClass} id="c-zip" name="zip" placeholder="Address or Town" type="text" autocomplete="postal-code" required />
      </div>
    </div>

    <div>
      <label class="sr-only" for="c-message">Message</label>
      <textarea class={inputClass} id="c-message" name="message" placeholder="How can we help? (optional)" rows="4"></textarea>
    </div>

    <div>
      <label class="sr-only" for="c-language">Preferred Language</label>
      <select class={`${inputClass} text-on-surface-variant`} id="c-language" name="language">
        {f.languageOptions.map((opt) => <option value={opt}>{opt}</option>)}
      </select>
    </div>

    <label class="flex items-start gap-3 text-[12px] text-on-surface-variant leading-snug">
      <input type="checkbox" name="sms_consent" class="mt-0.5 rounded border-outline-variant/60 text-primary focus:ring-primary" />
      <span>{f.smsConsent}</span>
    </label>

    <button
      class="w-full bg-primary-container hover:bg-primary text-white font-label-md text-[16px] py-4 rounded-btn mt-1 transition-colors flex justify-center items-center gap-2"
      type="submit"
    >
      {f.submitLabel}
      <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
    </button>
  </form>
</div>
