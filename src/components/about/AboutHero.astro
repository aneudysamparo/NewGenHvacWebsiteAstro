---
import { aboutHero as hero } from '../../data/about';
---

<section
  class="bg-surface-container-low py-section-gap px-margin-mobile md:px-margin-desktop relative overflow-hidden"
>
  <!-- Decorative gradient -->
  <div
    class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-bl from-primary-fixed/30 to-transparent pointer-events-none"
  >
  </div>

  <div
    class="max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center relative z-10"
  >
    <div class="flex flex-col gap-stack-lg max-w-xl">
      <div
        class="inline-block px-4 py-1.5 bg-secondary-container/20 text-on-secondary-container rounded-full font-label-md text-label-md w-max border border-secondary-container/30"
      >
        {hero.badge}
      </div>
      <h1
        class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-xl md:text-headline-xl text-on-background"
      >
        {hero.headline}
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">{hero.subcopy}</p>
      <div class="flex flex-wrap gap-stack-md mt-4">
        <a
          class="bg-primary hover:bg-primary-container text-on-primary font-label-md text-label-md px-8 py-4 rounded-lg shadow-sm transition-all flex items-center gap-2"
          href={hero.cta.href}
        >
          <span>{hero.cta.label}</span>
          <span class="material-symbols-outlined text-xl">arrow_downward</span>
        </a>
      </div>
    </div>

    <div
      class="relative h-[400px] lg:h-[500px] w-full rounded-xl overflow-hidden shadow-[0_4px_20px_rgba(0,67,106,0.15)] group"
    >
      <div
        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-emergency-orange z-20"
      >
      </div>
      <img
        alt={hero.image.alt}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        src={hero.image.src}
        width="512"
        height="512"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>
