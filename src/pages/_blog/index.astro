---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { blogIndex } from '../../data/blog';

// Published only (drafts — e.g. the parked NFPA-96 post — are excluded, §6.3).
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const [featured, ...rest] = posts;
---

<Layout title={blogIndex.title} description={blogIndex.metaDescription}>
  <!-- Hero -->
  <section
    class="bg-gradient-to-br from-surface to-surface-container-low px-margin-mobile md:px-margin-desktop py-section-gap"
  >
    <div class="max-w-container-max mx-auto text-center">
      <span
        class="inline-block py-1 px-3 rounded-full bg-surface-container-highest text-primary font-label-md text-label-md uppercase tracking-wider mb-6"
      >
        NewGen HVAC Blog
      </span>
      <h1 class="font-headline-xl text-headline-lg-mobile md:text-headline-xl text-on-surface mb-4">
        {blogIndex.heading}
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
        {blogIndex.subcopy}
      </p>
    </div>
  </section>

  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap flex flex-col gap-12">
    {featured && <PostCard post={featured} featured />}

    {
      rest.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {rest.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </div>
</Layout>
