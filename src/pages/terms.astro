---
import Layout from '../layouts/Layout.astro';
import LegalPage from '../components/legal/LegalPage.astro';
import { business } from '../data/business';

/*
 * TODO(legal): standard starter Terms of Service. JC should have this reviewed by
 * an attorney before launch and confirm any service-specific terms (warranty,
 * cancellation, deposits). No prices are stated here — pricing lives in written
 * quotes/agreements (CLAUDE.md §6.1: no public rates). Update date when revised.
 */
const lastUpdated = 'June 9, 2026';
---

<Layout
  title="Terms of Service | NewGen HVAC"
  description="The terms that govern your use of the NewGen HVAC (New Generation HVAC LLC) website and information."
>
  <LegalPage
    title="Terms of Service"
    lastUpdated={lastUpdated}
    intro={`These terms govern your use of ${'newgenhvac.com'}. By using this website, you agree to them.`}
  >
    <h2>Our services</h2>
    <p>
      {business.name} ({business.legalName}) provides HVAC, commercial refrigeration, and related
      equipment services for residential and commercial clients across the Merrimack Valley and Southern
      New Hampshire. Information on this website is provided for general guidance only.
    </p>

    <h2>Estimates & pricing</h2>
    <p>
      We provide free estimates. Any pricing is confirmed in a written quote or service agreement before
      work begins. Information on this site is not a binding offer and may change without notice.
    </p>

    <h2>Scheduling & service</h2>
    <p>
      Scheduling is subject to availability, and emergency-service availability may vary. The specific
      terms of any work we perform — including scope, warranty, and payment — are set out in the written
      agreement for that job, which controls if it differs from this website.
    </p>

    <h2>No professional advice</h2>
    <p>
      Content on this site is general information, not a professional assessment of your specific
      equipment. Please contact us for an evaluation of your system.
    </p>

    <h2>Website disclaimer & limitation of liability</h2>
    <p>
      This website is provided "as is." To the fullest extent permitted by law, we disclaim implied
      warranties regarding the website and are not liable for indirect or incidental damages arising from
      your use of it. Workmanship warranties, where offered, are governed by your service agreement.
    </p>

    <h2>Intellectual property</h2>
    <p>
      The content, branding, and materials on this website are owned by {business.legalName} and may not
      be copied or reused without permission.
    </p>

    <h2>Third-party links</h2>
    <p>We are not responsible for the content or practices of external websites we may link to.</p>

    <h2>Governing law</h2>
    <p>These terms are governed by the laws of the Commonwealth of Massachusetts.</p>

    <h2>Changes to these terms</h2>
    <p>We may update these terms from time to time. The "Last updated" date above reflects the latest version.</p>

    <h2>Contact us</h2>
    <p>
      {business.legalName} · {business.address.street}, {business.address.city}, {business.address.state}{' '}
      {business.address.zip} · <a href={business.phone.href}>{business.phone.display}</a> ·{' '}
      <a href={`mailto:${business.email}`}>{business.email}</a>
    </p>
  </LegalPage>
</Layout>
